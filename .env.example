# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=digital_twin_cim
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=60000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_must_be_very_long_and_secure
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_here_must_be_very_long
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=524288000
ALLOWED_FILE_TYPES=.gltf,.glb,.obj,.fbx,.dae,.ifc,.shp,.geojson,.json,.csv,.las,.laz,.ply

# Cache Configuration
CACHE_TTL=3600
CACHE_PREFIX=digital_twin:

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# WebSocket
WS_ENABLED=true
WS_PORT=3001

# Multitenancy
MULTI_TENANT_ENABLED=true
DEFAULT_TENANT_ID=default
