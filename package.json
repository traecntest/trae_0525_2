{
  "name": "digital-twin-cim-platform",
  "version": "1.0.0",
  "description": "Digital Twin City & CIM Platform - Comprehensive support system for urban digital twin and City Information Modeling",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src/**/*.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "init-db": "node database/init.js"
  },
  "keywords": [
    "digital-twin",
    "cim",
    "bim",
    "gis",
    "iot",
    "spatial",
    "3d-model",
    "nodejs"
  ],
  "author": "Digital Twin Platform Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "multer": "^1.4.5-lts.1",
    "stream-chunker": "^1.2.8",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "dayjs": "^1.11.10",
    "axios": "^1.6.2",
    "ws": "^8.16.0",
    "socket.io": "^4.7.3",
    "proj4": "^2.10.0",
    "geojson": "^0.5.0",
    "@turf/turf": "^6.5.0",
    "node-cron": "^3.0.3",
    "rate-limiter-flexible": "^4.0.0",
    "express-rate-limit": "^7.1.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "knex": "^3.1.0",
    "@types/node": "^20.10.6"
